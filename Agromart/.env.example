# Copy this file to .env and fill with your Supabase project values.
# Do NOT commit real secrets to source control.

# Supabase project URL (from your Supabase project settings)
SUPABASE_URL=https://your-project.supabase.co

# Supabase service role key (only required for server-side privileged operations)
SUPABASE_SERVICE_KEY=your-service-role-key

# Public anon key (optional; the server can use service key)
SUPABASE_ANON_KEY=your-anon-key

# Optional: override server port (default 3000)
PORT=3000

# Debug: set to true to enable verbose logs
DEBUG=false
